# /home/gihwan/.npu-sim.env (chmod 600)
# fpga_simulator self-hosted runner가 사용하는 서버 측 설정

# Docker 이미지 (이미 빌드되어 있어야 함)
IMAGE=fpga-simulator:latest

# 시뮬 작업 디렉토리 (모델/결과/로그 저장)
SIM_WORK_DIR=/home/gihwan/npu-sim-work

# Source repo (model_compression)에 PR/commit comment 작성용 PAT
# 권한: Repository=Kwon-GiHwan/model_compression, Pull requests R/W, Issues R/W
# 발급: https://github.com/settings/tokens?type=beta
SOURCE_REPO_COMMENT_TOKEN=ghp_여기에토큰값
